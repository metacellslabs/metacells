{
  "name": "metacells",
  "description": "MetaCells desktop shell and Meteor application",
  "author": {
    "name": "MetaCells contributors",
    "email": "team@metacells.com"
  },
  "main": "electron/main.js",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "cross-env METACELLS_ROLE=web meteor run --port 3400 --exclude-archs web.browser.legacy --no-lint",
    "start:web": "cross-env METACELLS_ROLE=web meteor run --port 3400 --exclude-archs web.browser.legacy --no-lint",
    "start:worker": "node scripts/run-meteor.js worker",
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "test:workbooks": "cross-env WORKBOOK_SPEC_DIR=tests/workbook-specs meteor test --once --driver-package meteortesting:mocha --port 3225",
    "test-app": "cross-env TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
    "desktop:prepare": "node scripts/desktop-prepare.js",
    "desktop:dev": "node scripts/electron-dev.js",
    "desktop:dev:frontend-only": "METACELLS_DESKTOP_NO_SERVER=1 node scripts/electron-dev.js",
    "desktop:pack": "node scripts/desktop-package.js --dir",
    "desktop:dist": "node scripts/desktop-package.js",
    "desktop:dist:mac": "npm run desktop:dist:mac:arm64 && npm run desktop:dist:mac:x64",
    "desktop:dist:mac:arm64": "node scripts/desktop-package.js --mac --arm64",
    "desktop:dist:mac:x64": "node scripts/desktop-package.js --mac --x64",
    "desktop:dist:linux": "node scripts/desktop-package.js --linux",
    "desktop:dist:win": "node scripts/desktop-package.js --win"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.5",
    "@swc/helpers": "^0.5.17",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "audio-decode": "^2.2.3",
    "exifr": "^7.1.3",
    "fast-xml-parser": "^5.3.1",
    "gif.js": "^0.2.0",
    "html2canvas": "^1.4.1",
    "image-size": "^2.0.2",
    "imapflow": "^1.2.13",
    "jimp": "^1.6.0",
    "jszip": "^3.10.1",
    "link-preview-js": "^3.2.0",
    "mammoth": "^1.10.0",
    "meteor-node-stubs": "^1.2.12",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stream": "^0.0.3",
    "turndown": "^7.2.1",
    "turndown-plugin-gfm": "^1.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@meteorjs/rspack": "^1.0.0",
    "@rsdoctor/rspack-plugin": "^1.2.3",
    "@rspack/cli": "^1.7.1",
    "@rspack/core": "^1.7.1",
    "@rspack/plugin-react-refresh": "^1.4.3",
    "@svgr/webpack": "^8.1.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "mongodb-memory-server-core": "^11.0.1",
    "node-addon-api": "^8.6.0",
    "node-gyp": "^12.2.0",
    "react-refresh": "^0.17.0"
  },
  "build": {
    "appId": "com.metacells.desktop",
    "productName": "MetaCells",
    "asar": true,
    "icon": "electron/assets/app-icon.png",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "dist/electron"
    },
    "extraResources": [
      {
        "from": ".desktop-runtime",
        "to": "desktop-runtime"
      }
    ],
    "files": [
      "electron/**/*",
      "package.json",
      "public/logo.png",
      "electron/assets/app-icon.png",
      "!node_modules/**/*",
      "!client/**/*",
      "!imports/**/*",
      "!server/**/*",
      "!.meteor/**/*",
      "!tests/**/*",
      "!docs/**/*",
      "!scripts/**/*",
      "!dist/**/*",
      "!.desktop-runtime/**/*",
      "!README.md"
    ],
    "mac": {
      "identity": null,
      "icon": "electron/assets/app-icon.png",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "backgroundColor": "#ffffff",
      "icon": null
    },
    "win": {
      "icon": "electron/assets/app-icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "electron/assets/app-icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "meteor": {
    "mainModule": {
      "client": "client/main.jsx",
      "server": "server/main.js"
    },
    "testModule": "tests/main.js",
    "modern": true
  }
}
